# BabelTower 开发模式 Dockerfile
FROM node:24-alpine
WORKDIR /app
# 启用 corepack 以使用 package.json 中固定的 pnpm 版本
RUN corepack enable

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY . .

# 直接调用 next（绕开 Windows 专用的 dev 脚本），读取容器注入的 DATABASE_URL
CMD pnpm exec prisma db push && pnpm exec next dev
