generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FileFormat {
  JSON
  PROPERTIES
  TS
}

enum TaskMode {
  SINGLE_SOURCE
  DUAL_SOURCE
}

enum TaskStatus {
  DRAFT
  SAVED
  READ_ONLY_HISTORY
  CANCELLED
}

enum SnapshotKind {
  IMPORTED
  AUTOSAVED
  MANUAL_DRAFT
  SAVED
  EXPORTED
}

enum ConflictType {
  DUPLICATE_IDENTICAL
  EXACT_CHINESE_DIFF_ENGLISH
  SIMILAR_CHINESE
}

enum ConflictSeverity {
  INFO
  WARNING
  BLOCKING
}

enum ConflictResolution {
  UNRESOLVED
  KEEP_EXISTING
  UPDATE_DICTIONARY
  IGNORE_SIMILAR
  EDIT_ROW
}

enum UserRole {
  ADMIN
  MAINTAINER
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @db.VarChar(64)
  passwordHash String   @map("password_hash") @db.Text
  role         UserRole @default(MAINTAINER)
  isActive     Boolean  @default(true) @map("is_active")
  tokenVersion Int      @default(1) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([role, isActive], map: "users_role_active_idx")
  @@map("users")
}

model Dictionary {
  id                String               @id @default(uuid()) @db.Uuid
  chineseText       String               @unique(map: "dictionary_chinese_text_uq") @map("chinese_text") @db.Text
  chineseHash       String               @unique(map: "dictionary_chinese_hash_uq") @map("chinese_hash") @db.VarChar(64)
  normalizedChinese String               @map("normalized_chinese") @db.Text
  englishText       String               @map("english_text") @db.Text
  normalizedEnglish String               @map("normalized_english") @db.Text
  tags              String[]             @default([])
  note              String?              @db.Text
  usageCount        Int                  @default(0) @map("usage_count")
  createdById       String?              @map("created_by_id") @db.Uuid
  updatedById       String?              @map("updated_by_id") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  revisions         DictionaryRevision[]
  conflicts         DictionaryConflict[]

  @@index([normalizedChinese], map: "dictionary_normalized_chinese_idx")
  @@index([normalizedEnglish], map: "dictionary_normalized_english_idx")
  @@map("dictionaries")
}

model DictionaryRevision {
  id              String     @id @default(uuid()) @db.Uuid
  dictionaryId    String     @map("dictionary_id") @db.Uuid
  dictionary      Dictionary @relation(fields: [dictionaryId], references: [id], onDelete: Cascade)
  previousEnglish String?    @map("previous_english") @db.Text
  nextEnglish     String     @map("next_english") @db.Text
  reason          String?    @db.Text
  changedById     String?    @map("changed_by_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([dictionaryId, createdAt], map: "dictionary_revisions_dictionary_created_idx")
  @@map("dictionary_revisions")
}

model ProductProject {
  id            String            @id @default(uuid()) @db.Uuid
  code          String            @unique @db.VarChar(64)
  name          String            @db.VarChar(128)
  description   String?           @db.Text
  currentTaskId String?           @unique @map("current_task_id") @db.Uuid
  tasks         TranslationTask[] @relation("ProjectTasks")
  createdById   String?           @map("created_by_id") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([name], map: "product_projects_name_idx")
  @@map("product_projects")
}

model TranslationTask {
  id                String               @id @default(uuid()) @db.Uuid
  projectId         String               @map("project_id") @db.Uuid
  project           ProductProject       @relation("ProjectTasks", fields: [projectId], references: [id], onDelete: Cascade)
  name              String               @db.VarChar(160)
  mode              TaskMode
  format            FileFormat
  sourceLocale      String               @default("zh-CN") @map("source_locale") @db.VarChar(32)
  targetLocale      String               @default("en-US") @map("target_locale") @db.VarChar(32)
  status            TaskStatus           @default(DRAFT)
  isEditable        Boolean              @default(true) @map("is_editable")
  latestVersion     Int                  @default(1) @map("latest_version")
  sourceFilename    String?              @map("source_filename") @db.VarChar(255)
  targetFilename    String?              @map("target_filename") @db.VarChar(255)
  createdById       String?              @map("created_by_id") @db.Uuid
  savedAt           DateTime?            @map("saved_at")
  dictionarySyncedAt DateTime?            @map("dictionary_synced_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  snapshots         TaskSnapshot[]
  draftRows         TaskDraftRow[]
  conflicts         DictionaryConflict[]

  @@index([projectId, updatedAt], map: "translation_tasks_project_updated_idx")
  @@index([status, isEditable], map: "translation_tasks_status_editable_idx")
  @@map("translation_tasks")
}

model TaskDraftRow {
  id              String          @id @default(uuid()) @db.Uuid
  taskId          String          @map("task_id") @db.Uuid
  task            TranslationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  rowKey          String          @map("row_key") @db.Text
  rowIndex        Int             @map("row_index")
  keyPath         Json            @map("key_path") @db.JsonB
  sourceValue     String?         @map("source_value") @db.Text
  translatedValue String?         @map("translated_value") @db.Text
  status          String          @db.VarChar(64)
  conflictLevel   String?         @map("conflict_level") @db.VarChar(32)
  metadata        Json?           @db.JsonB
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([taskId, rowKey], map: "task_draft_rows_task_row_key_uq")
  @@index([taskId, rowIndex], map: "task_draft_rows_task_row_index_idx")
  @@map("task_draft_rows")
}

model TaskSnapshot {
  id                String               @id @default(uuid()) @db.Uuid
  taskId            String               @map("task_id") @db.Uuid
  task              TranslationTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  version           Int
  kind              SnapshotKind
  standardDocuments Json                 @map("standard_documents") @db.JsonB
  previewRows       Json                 @map("preview_rows") @db.JsonB
  conflictSummary   Json                 @map("conflict_summary") @db.JsonB
  validationErrors  Json?                @map("validation_errors") @db.JsonB
  exportManifest    Json?                @map("export_manifest") @db.JsonB
  createdById       String?              @map("created_by_id") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at")
  conflicts         DictionaryConflict[]

  @@unique([taskId, version], map: "task_snapshots_task_version_uq")
  @@index([taskId, createdAt], map: "task_snapshots_task_created_idx")
  @@map("task_snapshots")
}

model DictionaryConflict {
  id                   String             @id @default(uuid()) @db.Uuid
  taskId               String?            @map("task_id") @db.Uuid
  task                 TranslationTask?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  snapshotId           String?            @map("snapshot_id") @db.Uuid
  snapshot             TaskSnapshot?      @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  dictionaryId         String?            @map("dictionary_id") @db.Uuid
  dictionary           Dictionary?        @relation(fields: [dictionaryId], references: [id], onDelete: SetNull)
  type                 ConflictType
  severity             ConflictSeverity
  resolution           ConflictResolution @default(UNRESOLVED)
  candidateKey         String?            @map("candidate_key") @db.Text
  candidateChineseText String             @map("candidate_chinese_text") @db.Text
  candidateEnglishText String?            @map("candidate_english_text") @db.Text
  existingChineseText  String?            @map("existing_chinese_text") @db.Text
  existingEnglishText  String?            @map("existing_english_text") @db.Text
  similarity           Float?
  reason               String             @db.Text
  resolvedById         String?            @map("resolved_by_id") @db.Uuid
  resolvedAt           DateTime?          @map("resolved_at")
  createdAt            DateTime           @default(now()) @map("created_at")

  @@index([taskId, severity], map: "dictionary_conflicts_task_severity_idx")
  @@index([snapshotId], map: "dictionary_conflicts_snapshot_idx")
  @@index([dictionaryId], map: "dictionary_conflicts_dictionary_idx")
  @@map("dictionary_conflicts")
}
