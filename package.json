{
  "name": "babeltower",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:validate": "prisma validate",
    "db:studio": "prisma studio",
    "openapi:validate": "npx @redocly/cli lint openapi/babeltower.v1.yaml",
    "ci:check": "npm run typecheck && npm run test && npm run db:validate"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "jszip": "^3.10.1",
    "next": "^15.3.0",
    "pinyin-pro": "^3.28.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@redocly/cli": "^1.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "jsdom": "^26.0.0",
    "prisma": "^6.7.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
